{
  "type": "module",
  "scripts": {
    "build": "postcss src/resources/styles.css -o dist/styles.css",
    "build:prod": "cross-env NODE_ENV=production postcss src/resources/styles.css -o dist/styles.css",
    "watch": "postcss src/resources/styles.css -o dist/styles.css --watch",
    "format": "npx prettier --write",
    "format:php": "node scripts/prettier-php.js"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.1.14",
    "autoprefixer": "^10.4.20",
    "cssnano": "^6.1.2",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.1",
    "postcss-nested": "^6.2.0",
    "tailwindcss": "^4.1.14"
  },
  "devDependencies": {
    "@prettier/plugin-php": "^0.24.0",
    "cross-env": "^7.0.3",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14"
  }
}